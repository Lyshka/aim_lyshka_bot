{
  "name": "aim-lyshka-bot",
  "private": true,
  "scripts": {
    "docker:up": "docker compose up --build -d",
    "docker:down": "docker compose down",
    "docker:logs": "docker compose logs -f",
    "docker:url": "docker compose exec tunnel cat /shared/webapp_url",
    "dev": "concurrently -n api,web -c teal,cyan \"npm --prefix backend run start:dev\" \"npm --prefix frontend run dev\"",
    "dev:backend": "npm --prefix backend run start:dev",
    "dev:frontend": "npm --prefix frontend run dev",
    "tunnel": "npx --yes cloudflared tunnel --url http://localhost:5173",
    "build": "npm --prefix backend run build && npm --prefix frontend run build"
  },
  "devDependencies": {
    "concurrently": "^9.2.1"
  }
}
