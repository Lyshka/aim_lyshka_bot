generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           BigInt            @id
  username     String?
  firstName    String?
  lastName     String?
  languageCode String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  medications  Medication[]
  intakes      MedicationIntake[]
  settings     UserSettings?
  appGrants    UserAppGrant[]
  catPosts     CatPost[]
  steamProfiles SteamProfile[]
  steamGames   SteamWishlistGame[]
  studySections StudySection[]
  studyItems    StudyItem[]
  financeAccounts FinanceAccount[]
  financeCash     FinanceCash[]
  financeDebts    FinanceDebt[]
  financeProviders FinanceProviderConnection[]
}

model App {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  description String         @default("")
  icon        String         @default("APP")
  color       String         @default("#1f6f5b")
  sortOrder   Int            @default(0)
  isSystem    Boolean        @default(false)
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  grants      UserAppGrant[]
}

model UserAppGrant {
  id        String   @id @default(cuid())
  userId    BigInt
  appId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([userId, appId])
  @@index([userId])
  @@index([appId])
}

model UserSettings {
  id                       String    @id @default(cuid())
  userId                   BigInt    @unique
  reminderHour             Int       @default(12)
  reminderMinute           Int       @default(0)
  catsReminderHour         Int       @default(6)
  catsReminderMinute       Int       @default(0)
  catsReminderChangedOn    String?
  catsLastDeliveryDate     String?
  timezone                 String    @default("Europe/Moscow")
  defaultInterval          Int       @default(1)
  notificationsMutedUntil  DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Medication {
  id           String             @id @default(cuid())
  userId       BigInt
  name         String
  tabletsCount Float
  mgPerTablet  Float
  intervalDays Int                @default(2)
  instructions String             @default("")
  active       Boolean            @default(true)
  nextDueAt    DateTime
  lastTakenAt  DateTime?
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  intakes      MedicationIntake[]

  @@index([userId, active])
  @@index([nextDueAt])
}

model MedicationIntake {
  id           String     @id @default(cuid())
  userId       BigInt
  medicationId String
  takenAt      DateTime   @default(now())
  tabletsCount Float
  mgPerTablet  Float
  totalMg      Float
  note         String?
  deletedAt    DateTime?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([userId, takenAt])
  @@index([medicationId, takenAt])
  @@index([userId, deletedAt])
}

model CatPost {
  id           String   @id @default(cuid())
  userId       BigInt
  deliveryDate String
  imageUrl     String
  imageKey     String
  text         String
  textKey      String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deliveryDate])
  @@unique([userId, imageKey])
  @@unique([userId, textKey])
  @@index([userId, createdAt])
}

model SteamProfile {
  id                   String               @id @default(cuid())
  userId               BigInt
  steamId              String
  vanityUrl            String?
  personaName          String               @default("")
  avatarUrl            String               @default("")
  active               Boolean              @default(false)
  lastSyncAt           DateTime?
  lastInventorySyncAt  DateTime?
  inventoryHidden      Boolean              @default(false)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  games                SteamWishlistGame[]
  inventory            SteamInventoryItem[]

  @@unique([userId, steamId])
  @@index([userId])
  @@index([steamId])
  @@index([userId, active])
}

model SteamWishlistGame {
  id             String       @id @default(cuid())
  userId         BigInt
  steamProfileId String
  appId          String
  name           String
  imageUrl       String       @default("")
  owned          Boolean      @default(false)
  priority       Int          @default(0)
  addedAt        DateTime?
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  steamProfile   SteamProfile @relation(fields: [steamProfileId], references: [id], onDelete: Cascade)

  @@unique([steamProfileId, appId])
  @@index([userId, owned])
  @@index([steamProfileId, owned])
  @@index([steamProfileId, priority])
}

model SteamInventoryItem {
  id             String       @id @default(cuid())
  steamProfileId String
  assetId        String
  classId        String
  instanceId     String       @default("")
  name           String
  marketHashName String       @default("")
  iconUrl        String       @default("")
  amount         Int          @default(1)
  marketable     Boolean      @default(false)
  typeLabel      String       @default("")
  rarity         String       @default("")
  exterior       String       @default("")
  priceUsd       Float?
  updatedAt      DateTime     @updatedAt
  steamProfile   SteamProfile @relation(fields: [steamProfileId], references: [id], onDelete: Cascade)

  @@unique([steamProfileId, assetId])
  @@index([steamProfileId])
  @@index([steamProfileId, marketable])
  @@index([steamProfileId, typeLabel])
}

model SteamMarketPrice {
  marketHashName String   @id
  priceUsd       Float?
  updatedAt      DateTime @updatedAt
}

model StudySection {
  id        String      @id @default(cuid())
  userId    BigInt
  title     String
  sortOrder Int         @default(0)
  deletedAt DateTime?
  createdAt DateTime    @default(now())
  updatedAt DateTime    @updatedAt
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  items     StudyItem[]

  @@index([userId, sortOrder])
  @@index([userId, deletedAt])
}

model StudyItem {
  id        String         @id @default(cuid())
  userId    BigInt
  sectionId String
  title     String
  note      String         @default("")
  sortOrder Int            @default(0)
  deletedAt DateTime?
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt
  user      User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  section   StudySection   @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  urls      StudyItemUrl[]

  @@index([userId, sectionId])
  @@index([sectionId, sortOrder])
  @@index([userId, deletedAt])
}

model StudyItemUrl {
  id        String    @id @default(cuid())
  itemId    String
  url       String
  title     String?
  sortOrder Int       @default(0)
  deletedAt DateTime?
  createdAt DateTime  @default(now())
  item      StudyItem @relation(fields: [itemId], references: [id], onDelete: Cascade)

  @@index([itemId, sortOrder])
  @@index([itemId, deletedAt])
}

model FinanceAccount {
  id        String                  @id @default(cuid())
  userId    BigInt
  key       String?
  name      String
  sortOrder Int                     @default(0)
  createdAt DateTime                @default(now())
  updatedAt DateTime                @updatedAt
  user      User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  balances  FinanceAccountBalance[]

  @@unique([userId, key])
  @@index([userId, sortOrder])
}

model FinanceAccountBalance {
  id        String         @id @default(cuid())
  accountId String
  currency  String
  amount    Float          @default(0)
  updatedAt DateTime       @updatedAt
  account   FinanceAccount @relation(fields: [accountId], references: [id], onDelete: Cascade)

  @@unique([accountId, currency])
  @@index([accountId])
}

model FinanceCash {
  id        String   @id @default(cuid())
  userId    BigInt
  currency  String
  amount    Float    @default(0)
  updatedAt DateTime @updatedAt
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, currency])
  @@index([userId])
}

model FinanceDebt {
  id         String   @id @default(cuid())
  userId     BigInt
  personName String
  amount     Float
  currency   String   @default("BYN")
  direction  String
  note       String   @default("")
  sortOrder  Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, sortOrder])
}

model FinanceProviderConnection {
  id            String    @id @default(cuid())
  userId        BigInt
  provider      String
  accessToken   String
  refreshToken  String?
  expiresAt     DateTime?
  scope         String    @default("")
  productsJson  String    @default("[]")
  lastSyncAt    DateTime?
  lastSyncError String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, provider])
  @@index([userId])
}
