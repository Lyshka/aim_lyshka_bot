generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           BigInt            @id
  username     String?
  firstName    String?
  lastName     String?
  languageCode String?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  medications  Medication[]
  intakes      MedicationIntake[]
  settings     UserSettings?
  appGrants    UserAppGrant[]
  healthDays   HealthDay[]
  catPosts     CatPost[]
  steamProfiles SteamProfile[]
  steamGames   SteamWishlistGame[]
}

model App {
  id          String         @id @default(cuid())
  slug        String         @unique
  name        String
  description String         @default("")
  icon        String         @default("APP")
  color       String         @default("#1f6f5b")
  sortOrder   Int            @default(0)
  isSystem    Boolean        @default(false)
  active      Boolean        @default(true)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  grants      UserAppGrant[]
}

model UserAppGrant {
  id        String   @id @default(cuid())
  userId    BigInt
  appId     String
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  app       App      @relation(fields: [appId], references: [id], onDelete: Cascade)

  @@unique([userId, appId])
  @@index([userId])
  @@index([appId])
}

model UserSettings {
  id                       String    @id @default(cuid())
  userId                   BigInt    @unique
  reminderHour             Int       @default(12)
  reminderMinute           Int       @default(0)
  catsReminderHour         Int       @default(6)
  catsReminderMinute       Int       @default(0)
  catsReminderChangedOn    String?
  catsLastDeliveryDate     String?
  timezone                 String    @default("Europe/Moscow")
  defaultInterval          Int       @default(1)
  notificationsMutedUntil  DateTime?
  createdAt                DateTime  @default(now())
  updatedAt                DateTime  @updatedAt
  user                     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Medication {
  id           String             @id @default(cuid())
  userId       BigInt
  name         String
  tabletsCount Float
  mgPerTablet  Float
  intervalDays Int                @default(2)
  instructions String             @default("")
  active       Boolean            @default(true)
  nextDueAt    DateTime
  lastTakenAt  DateTime?
  sortOrder    Int                @default(0)
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  user         User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  intakes      MedicationIntake[]

  @@index([userId, active])
  @@index([nextDueAt])
}

model MedicationIntake {
  id           String     @id @default(cuid())
  userId       BigInt
  medicationId String
  takenAt      DateTime   @default(now())
  tabletsCount Float
  mgPerTablet  Float
  totalMg      Float
  note         String?
  deletedAt    DateTime?
  user         User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  medication   Medication @relation(fields: [medicationId], references: [id], onDelete: Cascade)

  @@index([userId, takenAt])
  @@index([medicationId, takenAt])
  @@index([userId, deletedAt])
}

model CatPost {
  id           String   @id @default(cuid())
  userId       BigInt
  deliveryDate String
  imageUrl     String
  imageKey     String
  text         String
  textKey      String
  createdAt    DateTime @default(now())
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, deliveryDate])
  @@unique([userId, imageKey])
  @@unique([userId, textKey])
  @@index([userId, createdAt])
}

model HealthDay {
  id                       String   @id @default(cuid())
  userId                   BigInt
  day                      String
  steps                    Int?
  weightKg                 Float?
  bodyFatPercent           Float?
  leanBodyMassKg           Float?
  muscleMassKg             Float?
  waterPercent             Float?
  boneMassKg               Float?
  bmi                      Float?
  heightCm                 Float?
  walkingSpeedKmh          Float?
  walkingStepLengthCm      Float?
  source                   String   @default("manual")
  createdAt                DateTime @default(now())
  updatedAt                DateTime @updatedAt
  user                     User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, day])
  @@index([userId, day])
}

model SteamProfile {
  id                   String               @id @default(cuid())
  userId               BigInt
  steamId              String
  vanityUrl            String?
  personaName          String               @default("")
  avatarUrl            String               @default("")
  active               Boolean              @default(false)
  lastSyncAt           DateTime?
  lastInventorySyncAt  DateTime?
  inventoryHidden      Boolean              @default(false)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  user                 User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  games                SteamWishlistGame[]
  inventory            SteamInventoryItem[]

  @@unique([userId, steamId])
  @@index([userId])
  @@index([steamId])
  @@index([userId, active])
}

model SteamWishlistGame {
  id             String       @id @default(cuid())
  userId         BigInt
  steamProfileId String
  appId          String
  name           String
  imageUrl       String       @default("")
  owned          Boolean      @default(false)
  priority       Int          @default(0)
  addedAt        DateTime?
  updatedAt      DateTime     @updatedAt
  user           User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  steamProfile   SteamProfile @relation(fields: [steamProfileId], references: [id], onDelete: Cascade)

  @@unique([steamProfileId, appId])
  @@index([userId, owned])
  @@index([steamProfileId, owned])
  @@index([steamProfileId, priority])
}

model SteamInventoryItem {
  id             String       @id @default(cuid())
  steamProfileId String
  assetId        String
  classId        String
  instanceId     String       @default("")
  name           String
  marketHashName String       @default("")
  iconUrl        String       @default("")
  amount         Int          @default(1)
  marketable     Boolean      @default(false)
  typeLabel      String       @default("")
  rarity         String       @default("")
  exterior       String       @default("")
  priceUsd       Float?
  updatedAt      DateTime     @updatedAt
  steamProfile   SteamProfile @relation(fields: [steamProfileId], references: [id], onDelete: Cascade)

  @@unique([steamProfileId, assetId])
  @@index([steamProfileId])
  @@index([steamProfileId, marketable])
  @@index([steamProfileId, typeLabel])
}

model SteamMarketPrice {
  marketHashName String   @id
  priceUsd       Float?
  updatedAt      DateTime @updatedAt
}
